PORT=3000
NODE_ENV=development
# Docker Compose maps postgres to port 5434 (avoids conflicts with other local DBs)
DATABASE_URL=postgresql://nretail:nretail@localhost:5434/nretail
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-secure-random-string-at-least-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REGISTRATION_TOKEN_EXPIRES_IN=5m
